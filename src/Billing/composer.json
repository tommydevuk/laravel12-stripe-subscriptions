{
  "name": "stripe-laravel-cashier/billing",
  "description": "A Domain-Driven Design billing module for Laravel with Stripe integration, featuring subscriptions, payments, refunds, and webhook handling.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Your Organization",
      "email": "support@example.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "spatie/laravel-webhook-client": "^3.5",
    "stripe/stripe-php": "^14.0"
  },
  "require-dev": {
    "laravel/pint": "^1.24",
    "larastan/larastan": "^3.0",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^4.4",
    "pestphp/pest-plugin-laravel": "^4.1"
  },
  "autoload": {
    "psr-4": {
      "Billing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "pint",
    "analyze": "phpstan analyze src",
    "test": "pest",
    "test:coverage": "pest --coverage"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Billing\\Infrastructure\\Laravel\\BillingServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
